generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum UserRole {
  TEEN
  PARENT
  MENTOR
  ADMIN
}

enum PackStatus {
  FORMING
  ACTIVE
  ARCHIVED
}

enum MembershipRole {
  MEMBER
  FACILITATOR
}

enum MissionStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum AttemptStatus {
  STARTED
  COMPLETED
  ABANDONED
}

enum TrapCategory {
  ACCURATE_THINKING
  CATASTROPHIZING
  ALL_OR_NOTHING
  MIND_READING
  OVERGENERALIZATION
  LABELING
  EMOTIONAL_REASONING
  SHOULD_STATEMENTS
}

enum PackPostStatus {
  PENDING_REVIEW
  PUBLISHED
  BLOCKED
  ESCALATED
  EXPIRED
}

enum AliasStatus {
  ACTIVE
  ROTATED
  RETIRED
}

enum ReactionKind {
  I_RELATE
  I_TRIED_THIS
  THIS_HELPED
}

enum SafetyFlagType {
  SELF_HARM
  SUICIDE_RISK
  ABUSE_OR_NEGLECT
  IDENTITY_LEAK
  DOXXING
  SUBSTANCE_USE
  VIOLENCE_RISK
}

enum SafetyFlagStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum ModerationDecision {
  PUBLISH
  KEEP_BLOCKED
  ESCALATE_TO_ADMIN
  REQUEST_MANUAL_REVIEW
  EXPIRE
}

enum IdentityAccessReason {
  IMMINENT_HARM
  DOXXING_OR_IDENTITY_LEAK
  LEGAL_REQUEST
  CLINICAL_ESCALATION
  TRUST_AND_SAFETY_REVIEW
}

enum PackDigestAudience {
  PARENT
  MENTOR
}

enum EscalationSeverity {
  MONITOR
  CLINICAL_REFERRAL
  EMERGENCY
}

enum EscalationState {
  OPENED
  SUPERVISOR_NOTIFIED
  PARENT_INFORMED
  REFERRAL_SENT
  REFERRAL_ACCEPTED
  CLOSED
}

enum AlumniConversationStatus {
  PENDING
  SCHEDULED
  COMPLETED
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ChallengeSubmissionType {
  TEXT
  VOICE
  MIXED
}

enum CertificationStatus {
  PENDING
  CERTIFIED
  RENEWAL_DUE
  INACTIVE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           UserRole
  displayName    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teenProfile    TeenProfile?
  parentProfile  ParentProfile?
  mentorProfile  MentorProfile?
  packMemberships      PackMembership[]
  workshopEnrollments  WorkshopEnrollment[]
}

model TeenProfile {
  id                    String             @id @default(cuid())
  userId                String             @unique
  preferredName         String
  birthDate             DateTime
  onboardingStage       String?
  packId                String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack                  Pack?              @relation(fields: [packId], references: [id])
  parentLinks           ParentTeenLink[]   @relation("TeenToParentLinks")
  missionAttempts       MissionAttempt[]
  packReflections       PackReflection[]
  insightSnapshots      InsightSnapshot[]
  intakeRecord          IntakeRecord?
  dailySignals          DailySignal[]
  challengeAttempts     ChallengeAttempt[]
  escalationEvents      EscalationEvent[]
  alumniConversationsAsCurrentTeen AlumniConversation[] @relation("CurrentTeenToAlumni")
  alumniConversationsAsAlumni AlumniConversation[] @relation("AlumniToCurrentTeen")
  sessionBriefs         SessionBrief[]
  mentorSessions        MentorSession[]
}

model ParentProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  relationshipLabel  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  teenLinks          ParentTeenLink[]   @relation("ParentToTeenLinks")
}

model MentorProfile {
  id                        String             @id @default(cuid())
  userId                    String             @unique
  specialty                 String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  user                      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedPacks              Pack[]             @relation("PackMentor")
  insightSnapshots          InsightSnapshot[]
  escalationEvents          EscalationEvent[]
  sessionBriefs             SessionBrief[]
  mentorSessions            MentorSession[]
  trainingCohorts           TrainingCohort[]   @relation("MentorToTrainingCohort")
  mentorProfileExtended     MentorProfileExtended?
}

model ParentTeenLink {
  id                 String        @id @default(cuid())
  parentId           String
  teenId             String
  consentGrantedAt   DateTime?
  isPrimaryGuardian  Boolean       @default(false)
  createdAt          DateTime      @default(now())
  parent             ParentProfile @relation("ParentToTeenLinks", fields: [parentId], references: [id], onDelete: Cascade)
  teen               TeenProfile   @relation("TeenToParentLinks", fields: [teenId], references: [id], onDelete: Cascade)

  @@unique([parentId, teenId])
}

model Pack {
  id                 String             @id @default(cuid())
  name               String
  status             PackStatus         @default(FORMING)
  mentorId           String
  maxMembers         Int                @default(8)
  ageBand            String?
  cycleStart         DateTime?
  cycleEnd           DateTime?
  aliasRotationDays  Int                @default(7)
  isClosed           Boolean            @default(true)
  parentRawAccessBlocked Boolean        @default(true)
  mentorRawAccessRestricted Boolean     @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  mentor             MentorProfile      @relation("PackMentor", fields: [mentorId], references: [id], onDelete: Restrict)
  teens              TeenProfile[]
  memberships        PackMembership[]
  reflections        PackReflection[]
  aliases            PackAlias[]
  digests            PackDigest[]
  identityAccessAudits PackIdentityAccessAudit[]

  @@index([mentorId, status])
}

model PackMembership {
  id                 String          @id @default(cuid())
  userId             String
  packId             String
  role               MembershipRole  @default(MEMBER)
  isPeerPostingEnabled Boolean       @default(true)
  privacyAcknowledgedAt DateTime?
  joinedAt           DateTime        @default(now())
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack               Pack            @relation(fields: [packId], references: [id], onDelete: Cascade)
  aliases            PackAlias[]
  reflections        PackReflection[]
  reactions          PackReaction[]
  identityAccessAudits PackIdentityAccessAudit[]

  @@unique([userId, packId])
}

model PackAlias {
  id                 String          @id @default(cuid())
  packId             String
  membershipId       String
  alias              String
  status             AliasStatus     @default(ACTIVE)
  effectiveFrom      DateTime        @default(now())
  effectiveTo        DateTime?
  pack               Pack            @relation(fields: [packId], references: [id], onDelete: Cascade)
  membership         PackMembership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  reflections        PackReflection[]

  @@unique([packId, alias, effectiveFrom])
  @@index([membershipId, status])
}

model Mission {
  id                 String                 @id @default(cuid())
  slug               String                 @unique
  title              String
  narrativeIntro     String
  sensoryPrompt      String?
  status             MissionStatus          @default(DRAFT)
  estimatedMinutes   Int
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  decisionOptions    MissionDecisionOption[]
  attempts           MissionAttempt[]
}

model MissionDecisionOption {
  id                 String              @id @default(cuid())
  missionId          String
  label              String
  narrativeOutcome   String?
  sortOrder          Int
  mission            Mission             @relation(fields: [missionId], references: [id], onDelete: Cascade)
  trapLinks          MissionChoiceTrap[]
  missionChoices     MissionChoice[]

  @@unique([missionId, sortOrder])
}

model ThinkingTrap {
  id                 String              @id @default(cuid())
  code               TrapCategory        @unique
  label              String
  description        String
  severityWeight     Int                 @default(1)
  missionLinks       MissionChoiceTrap[]
  missionChoices     MissionChoice[]
}

model MissionChoiceTrap {
  id                 String               @id @default(cuid())
  decisionOptionId   String
  thinkingTrapId     String
  decisionOption     MissionDecisionOption @relation(fields: [decisionOptionId], references: [id], onDelete: Cascade)
  thinkingTrap       ThinkingTrap         @relation(fields: [thinkingTrapId], references: [id], onDelete: Cascade)

  @@unique([decisionOptionId, thinkingTrapId])
}

model MissionAttempt {
  id                 String          @id @default(cuid())
  teenId             String
  missionId          String
  status             AttemptStatus   @default(STARTED)
  startedAt          DateTime        @default(now())
  completedAt        DateTime?
  teen               TeenProfile     @relation(fields: [teenId], references: [id], onDelete: Cascade)
  mission            Mission         @relation(fields: [missionId], references: [id], onDelete: Restrict)
  choices            MissionChoice[]
  reflection         PackReflection?

  @@index([teenId, startedAt])
}

model MissionChoice {
  id                 String               @id @default(cuid())
  missionAttemptId   String
  decisionOptionId   String
  thinkingTrapId     String
  capturedAt         DateTime             @default(now())
  missionAttempt     MissionAttempt       @relation(fields: [missionAttemptId], references: [id], onDelete: Cascade)
  decisionOption     MissionDecisionOption @relation(fields: [decisionOptionId], references: [id], onDelete: Restrict)
  thinkingTrap       ThinkingTrap         @relation(fields: [thinkingTrapId], references: [id], onDelete: Restrict)

  @@index([thinkingTrapId, capturedAt])
  @@index([missionAttemptId, capturedAt])
}

model PackReflection {
  id                 String          @id @default(cuid())
  packId             String
  teenId             String
  membershipId       String
  missionAttemptId   String          @unique
  aliasId            String?
  displayAlias       String
  bodyCiphertext     String
  bodyPreview        String?
  branchLabel        String?
  moodTag            String?
  thinkingTrapCode   TrapCategory?
  status             PackPostStatus  @default(PENDING_REVIEW)
  publishedAt        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime        @default(now())
  pack               Pack            @relation(fields: [packId], references: [id], onDelete: Cascade)
  teen               TeenProfile     @relation(fields: [teenId], references: [id], onDelete: Cascade)
  membership         PackMembership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  alias              PackAlias?      @relation(fields: [aliasId], references: [id], onDelete: SetNull)
  missionAttempt     MissionAttempt  @relation(fields: [missionAttemptId], references: [id], onDelete: Cascade)
  reactions          PackReaction[]
  moderationEvents   PackModerationEvent[]
  safetyFlags        PackSafetyFlag[]

  @@index([packId, createdAt])
  @@index([packId, status, publishedAt])
}

model PackReaction {
  id                 String          @id @default(cuid())
  postId             String
  membershipId       String
  kind               ReactionKind
  createdAt          DateTime        @default(now())
  post               PackReflection  @relation(fields: [postId], references: [id], onDelete: Cascade)
  membership         PackMembership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([postId, membershipId, kind])
}

model PackSafetyFlag {
  id                 String            @id @default(cuid())
  postId             String
  flagType           SafetyFlagType
  status             SafetyFlagStatus  @default(OPEN)
  confidence         Float?
  detectedBy         String?
  notes              String?
  createdAt          DateTime          @default(now())
  resolvedAt         DateTime?
  post               PackReflection    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([flagType, status, createdAt])
}

model PackModerationEvent {
  id                 String              @id @default(cuid())
  postId             String
  actorUserId        String?
  decision           ModerationDecision
  notes              String?
  createdAt          DateTime            @default(now())
  post               PackReflection      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model PackIdentityAccessAudit {
  id                 String               @id @default(cuid())
  packId             String
  membershipId       String?
  actorUserId        String
  approvedByUserId   String?
  reason             IdentityAccessReason
  notes              String?
  createdAt          DateTime             @default(now())
  pack               Pack                 @relation(fields: [packId], references: [id], onDelete: Cascade)
  membership         PackMembership?      @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([packId, createdAt])
  @@index([actorUserId, createdAt])
}

model PackDigest {
  id                 String             @id @default(cuid())
  packId             String
  audience           PackDigestAudience
  weekStart          DateTime
  summary            String
  topThemes          Json
  flaggedCount       Int                @default(0)
  createdAt          DateTime           @default(now())
  pack               Pack               @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([packId, audience, weekStart])
  @@index([audience, weekStart])
}

model InsightSnapshot {
  id                    String         @id @default(cuid())
  teenId                String
  mentorId              String?
  weekStart             DateTime
  topTrapCodes          TrapCategory[]
  trapCounts            Json
  parentSummary         String
  sidewaysInvitation    String
  createdAt             DateTime       @default(now())
  teen                  TeenProfile    @relation(fields: [teenId], references: [id], onDelete: Cascade)
  mentor                MentorProfile? @relation(fields: [mentorId], references: [id], onDelete: SetNull)

  @@unique([teenId, weekStart])
  @@index([mentorId, weekStart])
}

model IntakeRecord {
  id                      String         @id @default(cuid())
  teenId                  String         @unique
  ageBand                 String
  primaryConcerns         String[]
  householdType           String
  caregiverStabilityFlag  Boolean        @default(false)
  safetyGateResponses     SafetyGateResponse?
  completedAt             DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  teen                    TeenProfile    @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([ageBand])
  @@index([completedAt])
}

model SafetyGateResponse {
  id                  String         @id @default(cuid())
  intakeRecordId      String         @unique
  question1Response   String
  question2Response   String
  question3Response   String
  isFlagged           Boolean        @default(false)
  flaggedAt           DateTime?
  createdAt           DateTime       @default(now())
  intakeRecord        IntakeRecord   @relation(fields: [intakeRecordId], references: [id], onDelete: Cascade)
  triageDecision      TriageDecision?

  @@index([isFlagged, createdAt])
}

model DailySignal {
  id                  String         @id @default(cuid())
  teenId              String
  moodSignal          Int
  freeTextNote        String?
  arcPosition         Int?
  submittedAt         DateTime       @default(now())
  teen                TeenProfile    @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([teenId, submittedAt])
  @@index([submittedAt])
}

model ChallengeAttempt {
  id                  String                  @id @default(cuid())
  teenId              String
  missionArcId        String?
  submissionType      ChallengeSubmissionType
  textContent         String?
  voiceNoteUrl        String?
  isOffline           Boolean                 @default(false)
  submittedAt         DateTime                @default(now())
  teen                TeenProfile             @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([teenId, submittedAt])
  @@index([submittedAt])
}

model EscalationEvent {
  id                    String               @id @default(cuid())
  teenId                String
  mentorId              String
  severity              EscalationSeverity
  state                 EscalationState      @default(OPENED)
  disclosurySummary     String
  checklistState        Json?
  clinicalPartnerId     String?
  isResolved            Boolean              @default(false)
  resolvedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  teen                  TeenProfile          @relation(fields: [teenId], references: [id], onDelete: Cascade)
  mentor                MentorProfile        @relation(fields: [mentorId], references: [id], onDelete: Restrict)
  triageDecisions       TriageDecision[]
  handoverRecords       HandoverRecord[]
  notificationLogs      NotificationLog[]

  @@index([teenId, createdAt])
  @@index([mentorId, state])
  @@index([state, createdAt])
}

model TriageDecision {
  id                    String               @id @default(cuid())
  escalationEventId     String
  safetyGateResponseId  String?              @unique
  severity              EscalationSeverity
  assessmentNotes       String?
  decidedAt             DateTime             @default(now())
  escalationEvent       EscalationEvent      @relation(fields: [escalationEventId], references: [id], onDelete: Cascade)
  safetyGateResponse    SafetyGateResponse?  @relation(fields: [safetyGateResponseId], references: [id], onDelete: SetNull)

  @@index([escalationEventId])
}

model HandoverRecord {
  id                    String               @id @default(cuid())
  escalationEventId     String
  clinicalPartnerName   String
  clinicalPartnerEmail  String
  referralLetterUrl     String?
  acceptedAt            DateTime?
  notes                 String?
  createdAt             DateTime             @default(now())
  escalationEvent       EscalationEvent      @relation(fields: [escalationEventId], references: [id], onDelete: Cascade)

  @@index([escalationEventId])
  @@index([acceptedAt])
}

model NotificationLog {
  id                    String               @id @default(cuid())
  escalationEventId     String?
  recipientUserId       String
  channel               NotificationChannel
  status                NotificationStatus   @default(PENDING)
  title                 String
  body                  String
  metadata              Json?
  sentAt                DateTime?
  readAt                DateTime?
  failureReason         String?
  createdAt             DateTime             @default(now())
  escalationEvent       EscalationEvent?     @relation(fields: [escalationEventId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, createdAt])
  @@index([channel, status])
  @@index([createdAt])
}

model AlumniConversation {
  id                    String                      @id @default(cuid())
  currentTeenId         String
  alumniMentorId        String
  status                AlumniConversationStatus    @default(PENDING)
  requestedAt           DateTime                    @default(now())
  scheduledFor          DateTime?
  completedAt           DateTime?
  feedbackNotes         String?
  currentTeen           TeenProfile                 @relation("CurrentTeenToAlumni", fields: [currentTeenId], references: [id], onDelete: Cascade)
  alumniMentor          TeenProfile                 @relation("AlumniToCurrentTeen", fields: [alumniMentorId], references: [id], onDelete: Cascade)

  @@index([currentTeenId, status])
  @@index([alumniMentorId, status])
  @@index([requestedAt])
}

model SessionBrief {
  id                    String               @id @default(cuid())
  mentorId              String
  teenId                String
  weekStart             DateTime
  patternSummary        String
  suggestedFocus        String
  openingQuestion       String
  challengeHighlights   Json?
  dailySignalInsights   Json?
  createdAt             DateTime             @default(now())
  mentor                MentorProfile        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  teen                  TeenProfile          @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@unique([mentorId, teenId, weekStart])
  @@index([weekStart])
}

model MentorSession {
  id                    String               @id @default(cuid())
  mentorId              String
  teenId                String
  scheduledFor          DateTime
  completedAt           DateTime?
  sessionNotes          String?
  safetyFlagsRaised     String[]
  positiveShifts        String?
  escalationTriggered   Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  mentor                MentorProfile        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  teen                  TeenProfile          @relation(fields: [teenId], references: [id], onDelete: Cascade)

  @@index([mentorId, scheduledFor])
  @@index([teenId, scheduledFor])
  @@index([completedAt])
}

model ClinicalPartner {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  phone                 String?
  specialization       String[]
  geography            String[]
  isAvailable           Boolean              @default(true)
  maxCaseload           Int?
  currentCaseload       Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([isAvailable])
  @@index([geography])
}

model TrainingCohort {
  id                    String               @id @default(cuid())
  name                  String
  startDate             DateTime
  endDate               DateTime
  status                String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  mentors               MentorProfile[]      @relation("MentorToTrainingCohort")

  @@index([status])
}

model MentorProfileExtended {
  id                    String               @id @default(cuid())
  mentorId              String               @unique
  certificationStatus   CertificationStatus  @default(PENDING)
  trainingCohortId      String?
  specialization        String[]
  maxTeensPerSession    Int                  @default(1)
  isActive              Boolean              @default(true)
  mentor                MentorProfile        @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([certificationStatus])
}

enum WorkshopStatus {
  PLANNING
  INTAKE_OPEN
  IN_PROGRESS
  BOOSTER_PHASE
  COMPLETED
  ARCHIVED
}

enum BoosterStatus {
  PENDING
  SENT
  COMPLETED
  MISSED
  ESCALATED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  WITHDRAWN
  COMPLETED
}

model Workshop {
  id                    String               @id @default(cuid())
  title                 String
  description           String?
  status                WorkshopStatus       @default(PLANNING)
  scheduledStartDate    DateTime
  scheduledEndDate      DateTime
  location              String?
  facilitatorId         String?
  maxParticipants       Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  cohorts               WorkshopCohort[]

  @@index([status])
  @@index([scheduledStartDate])
  @@index([facilitatorId])
}

model WorkshopCohort {
  id                    String               @id @default(cuid())
  workshopId            String
  name                  String
  description           String?
  assignmentRules       String?
  status                WorkshopStatus       @default(PLANNING)
  maxFamilies           Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  workshop              Workshop             @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  enrollments           WorkshopEnrollment[]

  @@index([workshopId, status])
  @@index([status])
}

model WorkshopEnrollment {
  id                    String               @id @default(cuid())
  cohortId              String
  parentUserId          String
  status                EnrollmentStatus     @default(PENDING)
  consentGrantedAt      DateTime?
  intakeCompletedAt     DateTime?
  triageCompletedAt     DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  cohort                WorkshopCohort       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  parentUser            User                 @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  attendanceRecords     WorkshopAttendance[]
  boosters              WorkshopBooster[]
  outcomes              WorkshopOutcome[]

  @@unique([cohortId, parentUserId])
  @@index([cohortId, status])
  @@index([parentUserId, status])
  @@index([status])
}

model WorkshopAttendance {
  id                    String               @id @default(cuid())
  enrollmentId          String
  sessionNumber         Int
  sessionDate           DateTime
  attended              Boolean              @default(false)
  arrivedAt             DateTime?
  departedAt            DateTime?
  materialsReceived     Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  enrollment            WorkshopEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sessionNotes          WorkshopSessionNote[]

  @@unique([enrollmentId, sessionNumber])
  @@index([enrollmentId, sessionDate])
  @@index([sessionDate, attended])
}

model WorkshopSessionNote {
  id                    String               @id @default(cuid())
  attendanceId          String
  facilitatorId         String?
  noteContent           String
  themesTags            String[]
  contractMilestoneNote String?
  journalMilestoneNote  String?
  artworkMilestoneNote  String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  attendance            WorkshopAttendance   @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
}

model WorkshopBooster {
  id                    String               @id @default(cuid())
  enrollmentId          String
  boosterDay            Int
  boosterDate           DateTime
  status                BoosterStatus        @default(PENDING)
  sentAt                DateTime?
  completedAt           DateTime?
  completionNotes       String?
  requiresEscalation    Boolean              @default(false)
  escalationReason      String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  enrollment            WorkshopEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, boosterDay])
  @@index([enrollmentId, boosterDay])
  @@index([boosterDate])
  @@index([status])
}

model WorkshopOutcome {
  id                    String               @id @default(cuid())
  enrollmentId          String
  boosterCompletionRate Float?
  academicLoadAssessment String?
  familyToneAssessment  String?
  referralStatus        String?
  referralSummary       String?
  schoolBridgeCompleted Boolean              @default(false)
  schoolBridgeSummary   String?
  qualityReviewScore    Float?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  enrollment            WorkshopEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId])
  @@index([enrollmentId])
}
