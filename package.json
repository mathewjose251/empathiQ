{
  "name": "empathiq",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm --filter parent-portal run build",
    "dev:mobile": "pnpm --filter teen-mobile start",
    "dev:web": "pnpm --filter parent-portal dev",
    "dev:engine": "pnpm --filter insight-engine dev",
    "prisma:generate": "pnpm --filter @empathiq/database prisma:generate",
    "prisma:migrate": "pnpm --filter @empathiq/database prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter @empathiq/database prisma:migrate:deploy"
  }
}
